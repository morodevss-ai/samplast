<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/launcher_home_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scaleType="centerCrop">
    <com.tuyenmonkey.mkloader.MKLoader
        android:id="@+id/loader"
    android:layout_width="@dimen/_50sdp"
    android:layout_height="@dimen/_40sdp"
    android:layout_marginBottom="@dimen/_5sdp"
    app:layout_constraintBottom_toTopOf="@+id/game_status"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:mk_color="@color/white"
    app:mk_type="Whirlpool"/>

    <TextView
        android:textSize="@dimen/_12sdp"
        android:textColor="#ffffffff"
        android:id="@+id/game_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ИДЁТ ЗАГРУЗКА ИГРЫ..."
        android:fontFamily="@font/akrobat_bold"
        android:layout_marginEnd="@dimen/_5sdp"
        android:letterSpacing="0.2"
        app:layout_constraintBottom_toBottomOf="@+id/start_h_line"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@+id/start_v_line"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintGuide_percent="0.03"/>
    <androidx.constraintlayout.widget.Guideline
        android:orientation="horizontal"
        android:id="@+id/start_h_line"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintGuide_percent="0.95"/>
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@+id/end_v_line"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintGuide_percent="0.95"/>
</androidx.constraintlayout.widget.ConstraintLayout>