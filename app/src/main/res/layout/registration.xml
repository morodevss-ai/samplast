<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar"
    android:id="@+id/br_registration_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/skin_layout"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:id="@+id/choose_skin_notf"
            android:visibility="gone"
            android:layout_width="200dp"
            android:layout_height="250dp"
            android:layout_marginStart="50dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:srcCompat="@drawable/register_choose_skin_notf"/>
        <ImageView
            android:id="@+id/choose_skin_left"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/register_choose_skin"/>
        <ImageView
            android:id="@+id/choose_skin_right"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/register_choose_skin_right"/>
        <com.google.android.material.button.MaterialButton
            android:textSize="@dimen/_15sdp"
            android:textColor="@color/white"
            android:id="@+id/choose_skin_btn"
            android:layout_width="@dimen/_150sdp"
            android:layout_height="@dimen/_50sdp"
            android:layout_marginBottom="@dimen/_10sdp"
            android:text="Начать игру"
            android:backgroundTint="@color/blue"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
        <ImageView
            android:id="@+id/choose_skin_notf_close"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:layout_marginTop="3dp"
            android:src="@drawable/cross"
            android:layout_marginEnd="5dp"
            app:layout_constraintEnd_toEndOf="@+id/choose_skin_notf"
            app:layout_constraintTop_toTopOf="@+id/choose_skin_notf"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/sex_layout"
        android:background="@drawable/choosesex_bg"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:textSize="25sp"
            android:textColor="#ffffff"
            android:gravity="center"
            android:id="@+id/textView16"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:text="КЕМ ВЫ БУДЕТЕ?"
            android:shadowColor="#000000"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="5"
            android:fontFamily="@font/din_pro_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:id="@+id/choosesex_male"
            android:background="@drawable/choosesex_male"
            android:layout_width="215dp"
            android:layout_height="215dp"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toTopOf="@+id/choosesex_btn"
            app:layout_constraintEnd_toEndOf="@+id/choosesex_btn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView16"/>
        <ImageView
            android:id="@+id/choosesex_female"
            android:background="@drawable/choosesex_female"
            android:layout_width="210dp"
            android:layout_height="205dp"
            android:adjustViewBounds="false"
            app:layout_constraintBottom_toBottomOf="@+id/choosesex_male"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/choosesex_btn"/>
        <com.google.android.material.button.MaterialButton
            android:textSize="16dp"
            android:id="@+id/choosesex_btn"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:layout_marginBottom="25dp"
            android:text="продолжить"
            android:backgroundTint="@color/yellow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/registration_layout"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraintLayout3"
            android:background="@drawable/authreg_bg_left"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginEnd="300dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:textSize="34sp"
                android:textColor="#ffffff"
                android:id="@+id/textView9"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:text="РЕГИСТРАЦИЯ"
                android:fontFamily="@font/montserrat_bold"
                android:layout_marginStart="25dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <ImageView
                android:id="@+id/reg_skin"
                android:background="@drawable/reg_skin"
                android:layout_width="200dp"
                android:layout_height="0dp"
                android:layout_marginTop="50dp"
                android:layout_marginStart="5dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textView9"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/regInfoContainer"
                android:background="@drawable/authreg_inputbg"
                android:visibility="gone"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_30sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/reg_skin"
                app:layout_constraintTop_toBottomOf="@+id/textView9">
                <TextView
                    android:textSize="12sp"
                    android:textColor="#ffffff"
                    android:gravity="center"
                    android:id="@+id/reg_infotitle"
                    android:paddingBottom="10dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Выберите способ авторизации!"
                    android:fontFamily="@font/montsserat_semibold"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="#8a8a8a"
                    android:id="@+id/reg_info"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="• Пароль должен состоять от 6 до 16 символов\10\10• Пароль чувствителен к регистру"
                    android:fontFamily="@font/montsserat_semibold"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/reg_infotitle"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView
                android:textColor="#ffffff"
                android:id="@+id/reg_nick"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nick_Name"
                android:fontFamily="@font/montserrat_bold"
                android:layout_marginStart="50dp"
                android:autofillHints="username"
                app:layout_constraintEnd_toEndOf="@+id/reg_skin"
                app:layout_constraintStart_toStartOf="@+id/reg_skin"
                app:layout_constraintTop_toBottomOf="@+id/textView9"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:background="@drawable/authreg_health"
                android:layout_width="0dp"
                android:layout_height="7dp"
                android:layout_marginStart="60dp"
                app:layout_constraintBottom_toTopOf="@+id/reg_skin"
                app:layout_constraintEnd_toEndOf="@+id/reg_skin"
                app:layout_constraintStart_toStartOf="@+id/reg_skin"
                app:layout_constraintTop_toBottomOf="@+id/reg_nick"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/reg_right1"
            android:background="@drawable/authreg_bg_right"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/constraintLayout3"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:textColor="#ffffff"
                android:id="@+id/textView7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="175dp"
                android:text="Выберите способ регистрации:"
                android:fontFamily="@font/montserrat_medium"
                android:layout_marginStart="25dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <ImageView
                android:id="@+id/reg_btn"
                android:layout_width="0dp"
                android:layout_height="35dp"
                android:layout_marginTop="10dp"
                android:layout_marginStart="25dp"
                android:layout_marginEnd="25dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textView7"
                app:srcCompat="@drawable/reg_createa"/>
            <TextView
                android:textColor="#ffffff"
                android:id="@+id/textView5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Скоро будет доступно:"
                android:fontFamily="@font/montserrat_medium"
                android:layout_marginStart="25dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/reg_btn"/>
            <ImageView
                android:id="@+id/imageView10"
                android:layout_width="0dp"
                android:layout_height="35dp"
                android:layout_marginTop="10dp"
                android:layout_marginStart="25dp"
                android:layout_marginEnd="25dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textView5"
                app:srcCompat="@drawable/reg_vk"/>
            <ImageView
                android:id="@+id/imageView11"
                android:layout_width="0dp"
                android:layout_height="35dp"
                android:layout_marginTop="5dp"
                android:layout_marginStart="25dp"
                android:layout_marginEnd="25dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/imageView10"
                app:srcCompat="@drawable/reg_google"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/reg_right2"
            android:background="@drawable/authreg_bg_right"
            android:visibility="visible"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/constraintLayout3">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constraintLayout4"
                android:background="@drawable/authreg_inputbg"
                android:visibility="invisible"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="175dp"
                android:layout_marginStart="25dp"
                android:layout_marginEnd="25dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <EditText
                    android:textSize="@dimen/_10sdp"
                    android:textColor="#ffffffff"
                    android:textColorHint="#5186a0"
                    android:id="@+id/reg_mail"
                    android:background="@android:color/transparent"
                    android:paddingTop="@dimen/_6sdp"
                    android:paddingBottom="@dimen/_7sdp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="Почта (необязательно)"
                    android:maxLines="1"
                    android:lines="1"
                    android:singleLine="true"
                    android:inputType="textShortMessage"
                    android:imeOptions="flagNoFullscreen|actionSend"
                    android:textCursorDrawable="@drawable/text_cursor"
                    android:fontFamily="@font/roboto_bold"
                    android:paddingStart="@dimen/_30sdp"
                    android:paddingEnd="@dimen/_6sdp"
                    android:autofillHints="emailAddress"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="10dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/reg_mail"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constraintLayout5"
                android:background="@drawable/authreg_inputbg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="25dp"
                android:layout_marginEnd="25dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/constraintLayout4">
                <EditText
                    android:textSize="@dimen/_10sdp"
                    android:textColor="#ffffffff"
                    android:textColorHint="#5186a0"
                    android:id="@+id/reg_password"
                    android:background="@android:color/transparent"
                    android:paddingTop="@dimen/_6sdp"
                    android:paddingBottom="@dimen/_7sdp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="Пароль"
                    android:maxLines="1"
                    android:lines="1"
                    android:singleLine="true"
                    android:inputType="textPassword"
                    android:imeOptions="flagNoFullscreen|actionSend"
                    android:textCursorDrawable="@drawable/text_cursor"
                    android:fontFamily="@font/roboto_bold"
                    android:paddingStart="@dimen/_30sdp"
                    android:paddingEnd="@dimen/_6sdp"
                    android:autofillHints="password"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="10dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/auth_key"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constraintLayout6"
                android:background="@drawable/authreg_inputbg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="25dp"
                android:layout_marginEnd="25dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/constraintLayout5">
                <EditText
                    android:textSize="@dimen/_10sdp"
                    android:textColor="#ffffffff"
                    android:textColorHint="#5186a0"
                    android:id="@+id/reg_passwordtwo"
                    android:background="@android:color/transparent"
                    android:paddingTop="@dimen/_6sdp"
                    android:paddingBottom="@dimen/_7sdp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="Повторите пароль"
                    android:maxLines="1"
                    android:lines="1"
                    android:singleLine="true"
                    android:inputType="textPassword"
                    android:imeOptions="flagNoFullscreen|actionSend"
                    android:textCursorDrawable="@drawable/text_cursor"
                    android:fontFamily="@font/roboto_bold"
                    android:paddingStart="@dimen/_30sdp"
                    android:paddingEnd="@dimen/_6sdp"
                    android:autofillHints="password"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="10dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/auth_key"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/reg_back"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:layout_marginStart="25dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:id="@+id/imageView13"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/authreg_back"/>
                <TextView
                    android:textColor="#5186a0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"
                    android:text="Вернуться"
                    android:fontFamily="@font/din_pro_bold"
                    app:layout_constraintBottom_toBottomOf="@+id/imageView13"
                    app:layout_constraintStart_toEndOf="@+id/imageView13"
                    app:layout_constraintTop_toTopOf="@+id/imageView13"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <com.google.android.material.button.MaterialButton
                android:textColor="@color/white"
                android:id="@+id/reg_play"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_marginTop="20dp"
                android:text="зарегистрироваться"
                android:layout_marginStart="25dp"
                android:layout_marginEnd="25dp"
                android:backgroundTint="#004261"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/constraintLayout6"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>